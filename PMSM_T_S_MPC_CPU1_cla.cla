// Initial Values for Task1
__interrupt void Cla1Task8 ( void )
{
    unsigned int i;

    float reV[7]={ 2.0, 1.0,-1.0,-2.0,-1.0, 1.0, 0.0 };
    float imV[7]={ 0.0, 1.0, 1.0, 0.0,-1.0,-1.0, 0.0 };

    float V_bus = 24.0;

    float reV_base = V_bus/3.0;
    float imV_base = V_bus*OneOverSqrt3;
    for(i=7;i--;)
    {
        Vre[i] = reV[i] * reV_base;
        V_d[i] = Vre[i];
        Vim[i] = imV[i] * imV_base;
        V_q[i] = Vim[i];

    }
    i_d_latch = 0.0;
    i_q_latch = 0.0;
    //float x_mins_prot[6] = { -0.5, -1.0, -1.0, -0.5, 0.5, 0.5 };
    //float x_maxs_prot[6] = {  0.5, -0.5, -0.5,  0.5, 1.0, 1.0 };
}

